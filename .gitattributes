# --- Project Silver Arrow: Git Attributes ---

# Handle line endings automatically
* text=auto

# Denote all files that are truly binary and should not be modified
*.exe binary
*.bin binary
*.elf binary
*.hex binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Ensure proper syntax highlighting on GitHub for specific files
*.ino linguist-language=C++
*.py linguist-language=Python
