/*
 * Argentum Silver Arrow - ESP32 Configuration Template
 * 
 * Instructions:
 * 1. Copy this file as "config.h" in the same directory.
 * 2. Update with your real network and bridge credentials.
 */

#ifndef CONFIG_H
#define CONFIG_H

// --- 📡 WiFi Configuration ---
#define WIFI_SSID     "YOUR_SSID_HERE"
#define WIFI_PASSWORD "YOUR_PASSWORD_HERE"

// --- 🌉 Bridge Connection ---
// Point this to the machine IP running argentum_bridge.py
#define BRIDGE_IP     "192.168.32.3"
#define BRIDGE_PORT   8001

// --- 🚥 Hardware Configuration ---
#define LED_PIN       4    // Data Pin for NeoPixel
#define NUM_LEDS      2    // Number of LEDs in the strip
#define BRIGHTNESS    50   // LED Brightness (0-255)

#endif // CONFIG_H
